{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csub.example/contracts/vendor-records.schema.json",
  "title": "Vendor records",
  "$defs": {
    "Vendor": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "vendor_id", "name", "official_domain"],
      "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "vendor_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "official_domain": {"type": ["string", "null"]}
      }
    },
    "VendorProduct": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "product_id", "vendor_id", "name"],
      "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "product_id": {"type": "string", "minLength": 1},
        "vendor_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "VendorContact": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "contact_id", "vendor_id", "name", "email"],
      "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "contact_id": {"type": "string", "minLength": 1},
        "vendor_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "email": {"type": "string", "format": "email"}
      }
    },
    "VendorCase": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "case_id", "product_id", "use_case", "scope", "lifecycle", "vendor_visible_comment", "vendor_next_actions"],
      "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "case_id": {"type": "string", "minLength": 1},
        "product_id": {"type": "string", "minLength": 1},
        "use_case": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "lifecycle": {"enum": ["draft", "invited", "opened", "in_progress", "submitted", "analyzing", "needs_review", "approved", "changes_requested", "declined", "writeback_complete"]},
        "vendor_visible_comment": {"type": ["string", "null"], "minLength": 1, "maxLength": 2000},
        "vendor_next_actions": {
          "type": "array", "maxItems": 10,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "required_evidence": {
          "type": "array", "maxItems": 20,
          "description": "Deterministic policy evidence keys captured at registration (issue #63).",
          "items": {"type": "string", "minLength": 1}
        },
        "policy_route": {"type": ["string", "null"]}
      }
    },
    "CreateVendor": {
      "type": "object", "additionalProperties": false, "required": ["name"],
      "properties": {"name": {"type": "string", "minLength": 1}, "official_domain": {"type": "string", "minLength": 1}}
    },
    "CreateProduct": {
      "type": "object", "additionalProperties": false, "required": ["vendor_id", "name"],
      "properties": {"vendor_id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}}
    },
    "CreateContact": {
      "type": "object", "additionalProperties": false, "required": ["vendor_id", "name", "email"],
      "properties": {"vendor_id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}, "email": {"type": "string", "format": "email"}}
    }
  }
}
