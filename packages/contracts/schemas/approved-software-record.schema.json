{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csub.example/contracts/approved-software-record.schema.json",
  "title": "ApprovedSoftwareRecord",
  "description": "Lossless normalized workbook row. Catalog membership never implies blanket approval.",
  "type": "object", "additionalProperties": false,
  "required": ["workspace_id", "record_id", "canonical_name", "vendor", "source_row", "approval_inferred"],
  "properties": {
    "workspace_id": {"type": "string", "minLength": 1}, "record_id": {"type": "string", "minLength": 1},
    "canonical_name": {"type": "string", "minLength": 1}, "vendor": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}}, "short_name": {"type": ["string", "null"]},
    "platform": {"type": "array", "items": {"type": "string"}}, "audience": {"type": ["string", "null"]},
    "department": {"type": ["string", "null"]}, "assignment": {"type": ["string", "null"]},
    "support": {"type": ["string", "null"]}, "location": {"type": ["string", "null"]},
    "licensing": {"type": ["string", "null"]}, "supported_software": {"type": ["string", "null"]},
    "campus_license": {"type": ["string", "null"]}, "source_hash": {"type": ["string", "null"]},
    "source_row_number": {"type": ["integer", "null"]}, "normalized_identity": {"type": ["string", "null"]},
    "approval_inferred": {"const": false},
    "source_row": {"type": "object", "additionalProperties": {"type": ["string", "null"]}},
    "source_coordinates": {"oneOf": [{"$ref": "https://csub.example/contracts/source-coordinates.schema.json"}, {"type": "null"}]},
    "extraction_warnings": {"type": "array", "items": {"type": "string"}}
  }
}
