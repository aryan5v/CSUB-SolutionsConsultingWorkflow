{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csub.example/contracts/vendor-intake.schema.json",
  "title": "Vendor invitation and submission contracts",
  "$defs": {
    "IssueInvite": {
      "type": "object", "additionalProperties": false, "required": ["contact_id"],
      "properties": {"contact_id": {"type": "string", "minLength": 1}}
    },
    "InviteProjection": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "invite_id", "case_id", "product_id", "contact_id", "issued_at", "expires_at", "status", "opened_at", "revoked_at", "submitted_at", "replaced_invite_id"],
      "properties": {
        "workspace_id": {"type": "string"}, "invite_id": {"type": "string"}, "case_id": {"type": "string"},
        "product_id": {"type": "string"}, "contact_id": {"type": "string"},
        "issued_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"},
        "status": {"enum": ["issued", "opened", "in_progress", "submitted", "revoked", "expired"]},
        "opened_at": {"type": ["string", "null"]}, "revoked_at": {"type": ["string", "null"]},
        "submitted_at": {"type": ["string", "null"]}, "replaced_invite_id": {"type": ["string", "null"]}
      }
    },
    "VendorInviteRecord": {
      "type": "object", "additionalProperties": false,
      "description": "Internal persistence record; never use as a public response.",
      "required": ["workspace_id", "invite_id", "case_id", "product_id", "contact_id", "token_hash", "issued_at", "expires_at", "status"],
      "properties": {
        "workspace_id": {"type": "string"}, "invite_id": {"type": "string"}, "case_id": {"type": "string"},
        "product_id": {"type": "string"}, "contact_id": {"type": "string"},
        "token_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "issued_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"},
        "status": {"enum": ["issued", "opened", "in_progress", "submitted", "revoked", "expired"]},
        "opened_at": {"type": ["string", "null"]}, "revoked_at": {"type": ["string", "null"]},
        "submitted_at": {"type": ["string", "null"]}, "replaced_invite_id": {"type": ["string", "null"]}
      }
    },
    "EvidenceMetadata": {
      "type": "object", "additionalProperties": false,
      "required": ["filename", "content_type", "size_bytes", "sha256"],
      "properties": {
        "filename": {"type": "string", "minLength": 1, "maxLength": 255},
        "content_type": {"type": "string", "minLength": 1},
        "size_bytes": {"type": "integer", "minimum": 0, "maximum": 50000000},
        "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "content_base64": {"type": "string", "minLength": 1, "description": "Optional inline document bytes (base64, small files only; both runtimes cap JSON bodies at ~1 MB). Stored through the evidence storage seam after the sha256 and size are verified, so content validation (issue 36) can parse them."}
      }
    },
    "EvidenceArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "artifact_id", "submission_id", "filename", "content_type", "size_bytes", "sha256", "untrusted"],
      "properties": {
        "workspace_id": {"type": "string"}, "artifact_id": {"type": "string"}, "submission_id": {"type": "string"},
        "filename": {"type": "string"}, "content_type": {"type": "string"}, "size_bytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}, "untrusted": {"const": true}
      }
    },
    "TrustCenter": {
      "type": "object", "additionalProperties": false, "required": ["trust_center_url"],
      "properties": {"trust_center_url": {"type": "string", "minLength": 1}}
    },
    "Answers": {
      "type": "object", "additionalProperties": false, "required": ["answers"],
      "properties": {"answers": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}}}
    },
    "Coverage": {
      "type": "object", "additionalProperties": false, "required": ["requirement_id", "evidence_artifact_ids"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"},
        "evidence_artifact_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "CoverageItem": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "coverage_id", "submission_id", "requirement_id", "profile_version_id", "evidence_artifact_ids", "source_citation"],
      "properties": {
        "workspace_id": {"type": "string"}, "coverage_id": {"type": "string"}, "submission_id": {"type": "string"},
        "requirement_id": {"type": "string"}, "profile_version_id": {"type": "string"},
        "evidence_artifact_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "source_citation": {"type": "object", "required": ["source_id"], "properties": {"source_id": {"type": "string"}}, "additionalProperties": true}
      }
    },
    "ReviewStatusChecklistItem": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_id", "question", "expected_evidence", "status"],
      "properties": {
        "requirement_id": {"type": "string"}, "question": {"type": "string"},
        "expected_evidence": {"type": "array", "items": {"type": "string"}},
        "status": {
          "enum": ["received", "processing", "accepted", "invalid", "stale", "outstanding"],
          "description": "received: evidence artifact linked to the requirement; processing: unvalidated free-text answer only; accepted/invalid/stale: set by evidence validation (issue #36); outstanding: nothing provided."
        }
      }
    },
    "ReviewStatus": {
      "type": "object", "additionalProperties": false,
      "description": "Vendor-safe status projection; internal lifecycle states collapse to a small stage vocabulary and no reviewer-only data is included.",
      "required": ["invite", "vendor", "product", "submission_status", "intake_analysis_complete", "review_stage", "outcome", "checklist"],
      "properties": {
        "invite": {
          "type": "object", "additionalProperties": false,
          "required": ["invite_id", "case_id", "status", "expires_at"],
          "properties": {
            "invite_id": {"type": "string"}, "case_id": {"type": "string"},
            "status": {"enum": ["issued", "opened", "in_progress", "submitted", "revoked", "expired"]},
            "expires_at": {"type": "string", "format": "date-time"}
          }
        },
        "vendor": {
          "type": "object", "additionalProperties": false, "required": ["vendor_id", "name"],
          "properties": {"vendor_id": {"type": "string"}, "name": {"type": "string"}}
        },
        "product": {
          "type": "object", "additionalProperties": false, "required": ["product_id", "name"],
          "properties": {"product_id": {"type": "string"}, "name": {"type": "string"}}
        },
        "submission_status": {"enum": ["draft", "finalized"]},
        "intake_analysis_complete": {"type": "boolean"},
        "review_stage": {"enum": ["collecting_evidence", "under_review", "changes_requested", "decided"]},
        "outcome": {"enum": ["approved", "declined", null]},
        "checklist": {"type": "array", "items": {"$ref": "#/$defs/ReviewStatusChecklistItem"}}
      }
    },
    "EvidenceExpiryRecord": {
      "type": "object", "additionalProperties": false,
      "description": "When a validated, time-bound evidence document stops being current (issue 53). Derived only from validated fields; drives post-approval monitoring.",
      "required": ["workspace_id", "expiry_id", "case_id", "submission_id", "artifact_id", "filename", "evidence_type", "expires_on", "source_citation"],
      "properties": {
        "workspace_id": {"type": "string"}, "expiry_id": {"type": "string"},
        "case_id": {"type": "string"}, "submission_id": {"type": "string"}, "artifact_id": {"type": "string"},
        "filename": {"type": "string"},
        "evidence_type": {"enum": ["coi", "pentest", "pci"]},
        "expires_on": {"type": "string", "format": "date"},
        "source_citation": {"type": "object", "required": ["source_id"], "properties": {"source_id": {"type": "string"}}, "additionalProperties": true}
      }
    },
    "RenewalRecord": {
      "type": "object", "additionalProperties": false,
      "description": "A scoped re-review case opened for expired approved evidence (issue 53); the historical approval is never mutated.",
      "required": ["workspace_id", "renewal_id", "source_case_id", "renewal_case_id", "expired_evidence_types", "opened_at"],
      "properties": {
        "workspace_id": {"type": "string"}, "renewal_id": {"type": "string"},
        "source_case_id": {"type": "string"}, "renewal_case_id": {"type": "string"},
        "expired_evidence_types": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "opened_at": {"type": "string", "format": "date-time"}
      }
    },
    "EvidenceValidationFinding": {
      "type": "object", "additionalProperties": false,
      "description": "One failed or manual-review content check on an evidence artifact (issue 36). Only failures are persisted; they keep the requirement unresolved instead of counting the document as received. disposition 'manual_review' marks documents a human must decide on (unreadable dates, vendor/product mismatch, TBD rules such as PCI currency — issue 52).",
      "required": ["workspace_id", "finding_id", "submission_id", "artifact_id", "filename", "evidence_type", "check", "reason", "source_citation"],
      "properties": {
        "workspace_id": {"type": "string"}, "finding_id": {"type": "string"},
        "submission_id": {"type": "string"}, "artifact_id": {"type": "string"},
        "filename": {"type": "string"},
        "evidence_type": {"enum": ["coi", "pentest", "pci", "unknown"]},
        "check": {"type": "string"}, "reason": {"type": "string"},
        "disposition": {"enum": ["failed", "manual_review"]},
        "source_citation": {"type": "object", "required": ["source_id"], "properties": {"source_id": {"type": "string"}}, "additionalProperties": true}
      }
    },
    "Submission": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_id", "submission_id", "invite_id", "case_id", "product_id", "version", "status", "trust_center_url", "answers", "evidence_artifact_ids", "coverage_ids", "updated_at", "finalized_at"],
      "properties": {
        "workspace_id": {"type": "string"}, "submission_id": {"type": "string"}, "invite_id": {"type": "string"},
        "case_id": {"type": "string"}, "product_id": {"type": "string"}, "version": {"type": "integer", "minimum": 1},
        "status": {"enum": ["draft", "finalized"]}, "trust_center_url": {"type": ["string", "null"]},
        "answers": {"type": "object", "additionalProperties": {"type": "string"}},
        "evidence_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "coverage_ids": {"type": "array", "items": {"type": "string"}},
        "updated_at": {"type": ["string", "null"]}, "finalized_at": {"type": ["string", "null"]}
      }
    }
  }
}
