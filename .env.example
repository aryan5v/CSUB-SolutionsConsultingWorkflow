# Copy to .env for local-only configuration when the application needs it.
# Never commit .env, credentials, tokens, or institutional data.

AWS_REGION=us-west-2
AWS_PROFILE=
APP_ENV=development

# Set false to use live AWS (Bedrock/S3/DynamoDB) instead of local fakes.
USE_LOCAL_FAKES=true

# Foundation resource names/ARNs (from the CDK ReviewFoundationStack outputs).
# Leave blank to keep local fakes; fill from your own account's outputs — do NOT
# commit real values (they carry account IDs).
RAW_BUCKET=
NORMALIZED_BUCKET=
CASES_TABLE=
DATA_KEY_ARN=

# Base URL for the case-scoped vendor upload portal link.
PORTAL_BASE_URL=https://portal.example.edu

# Optional Bedrock inference-profile overrides (defaults are pinned in config).
BEDROCK_REASONING_MODEL_ID=
BEDROCK_EXTRACTION_MODEL_ID=
BEDROCK_FALLBACK_MODEL_ID=
BEDROCK_GUARDRAIL_ID=
